<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F6F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:background="@drawable/bg_header"
            android:padding="20dp">

            <!-- Logo -->

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/logoisbal"/>

            <!-- Foto Profil -->

            <ImageView
                android:id="@+id/imgProfil"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginTop="50dp"
                android:src="@drawable/profil"/>

            <!-- Halo -->

            <TextView
                android:id="@+id/txtHalo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imgProfil"
                android:layout_marginStart="15dp"
                android:layout_marginTop="55dp"
                android:text="Halo,"
                android:textColor="#FFFFFF"
                android:textSize="14sp"/>

            <!-- Nama -->

            <TextView
                android:id="@+id/txtNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imgProfil"
                android:layout_below="@id/txtHalo"
                android:layout_marginStart="15dp"
                android:text="Marsya Maharani Monica Redia"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="17sp"/>

            <!-- NIM -->

            <TextView
                android:id="@+id/txtNim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imgProfil"
                android:layout_below="@id/txtNama"
                android:layout_marginStart="15dp"
                android:text="NIM : 2511500087"
                android:textColor="#FFFFFF"
                android:textSize="13sp"/>

        </RelativeLayout>

        <!-- MENU HARI -->

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSelasa"
                    android:layout_width="90dp"
                    android:layout_height="45dp"
                    android:text="Selasa"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button"/>

                <Button
                    android:id="@+id/btnRabu"
                    android:layout_width="90dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="10dp"
                    android:text="Rabu"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button"/>

                <Button
                    android:id="@+id/btnKamis"
                    android:layout_width="90dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="10dp"
                    android:text="Kamis"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button"/>

                <Button
                    android:id="@+id/btnJumat"
                    android:layout_width="90dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="10dp"
                    android:text="Jumat"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button"/>

            </LinearLayout>

        </HorizontalScrollView>

        <!-- JUDUL -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jadwal Kuliah"
            android:textStyle="bold"
            android:textSize="22sp"
            android:layout_marginStart="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tahun Ajaran 2025/2026 Semester Genap"
            android:textSize="13sp"
            android:textColor="#777777"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="10dp">
        </TextView>
        <!-- CARD JADWAL KULIAH -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="15dp"
                android:background="@drawable/bg_card">

                <!-- Tanggal -->

                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_date">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="27"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="#7B2EF2"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jun"
                        android:textStyle="bold"
                        android:textColor="#7B2EF2"/>

                </LinearLayout>

                <!-- Informasi Mata Kuliah -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MT102"
                        android:textColor="#888888"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agama"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#000000"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="13.50 - 15.20"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ruang 2.1.6"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Suharno, S.Ag., MH"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="2 SKS"
                        android:textColor="#7B2EF2"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>
        <!-- JUDUL UAS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Jadwal UAS"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lihat Semua"
                android:textColor="#D96CF5"
                android:textStyle="bold"
                android:textSize="13sp"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="10dp"
            android:text="Tahun Ajaran 2025/2026 Semester Genap"
            android:textSize="12sp"
            android:textColor="#888888"/>

        <!-- CARD UAS -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="15dp"
                android:background="@drawable/bg_card">

                <!-- Tanggal -->

                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_date">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="27"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="#D96CF5"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jun"
                        android:textStyle="bold"
                        android:textColor="#D96CF5"/>

                </LinearLayout>

                <!-- Informasi -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agama"
                        android:textStyle="bold"
                        android:textSize="17sp"
                        android:textColor="#000000"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="13.50 - 15.20"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ruang 2.1.6"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Suharno, S.Ag., MH"
                        android:textSize="13sp"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>
        <!-- ================= CARD CATATAN ================= -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="15dp"
                android:background="@drawable/bg_card">

                <!-- Icon Catatan -->

                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/ic_note"/>

                <!-- Isi Catatan -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Belum ada catatan"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#000000"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tambahkan catatan agar tidak lupa dengan tugas atau jadwal penting."
                        android:textColor="#777777"
                        android:textSize="12sp"/>

                </LinearLayout>

                <!-- Tombol -->

                <Button
                    android:id="@+id/btnTambahCatatan"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Tambah"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- PENUTUP -->

    </LinearLayout>

</ScrollView>