<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ================= HEADER ================= -->

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/bg_header"
            android:padding="20dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_back"
                android:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btnBack"
                android:layout_marginStart="18dp"
                android:text="Catatan &amp; Pengingat"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="22sp"/>

        </RelativeLayout>

        <!-- ================= CARD ================= -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-30dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="26dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- Judul -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Catatan Anda"
                    android:textColor="#222222"
                    android:textStyle="bold"
                    android:textSize="20sp"/>

                <!-- Input Catatan -->

                <EditText
                    android:id="@+id/edtCatatan"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_input"
                    android:gravity="top|start"
                    android:hint="Contoh : Kumpulkan Tugas XX"
                    android:padding="18dp"
                    android:textColor="#222222"
                    android:textColorHint="#A0A0A0"
                    android:textSize="15sp"/>

                <!-- Counter -->

                <TextView
                    android:id="@+id/txtCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="6dp"
                    android:text="0/25"
                    android:textColor="#888888"
                    android:textSize="12sp"/>

                <!-- Garis -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#D7D7D7"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="18dp"
                        android:text="Pengingat"
                        android:textColor="#8C8C8C"
                        android:textStyle="bold"
                        android:textSize="17sp"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#D7D7D7"/>

                </LinearLayout>

                <!-- ================= TANGGAL BATAS ================= -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="26dp"
                    android:text="Tanggal Batas"
                    android:textColor="#222222"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:id="@+id/imgTanggal"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_calendar"
                            android:tint="#D84EF7"/>

                        <EditText
                            android:id="@+id/edtTanggal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:background="@android:color/transparent"
                            android:clickable="true"
                            android:cursorVisible="false"
                            android:focusable="false"
                            android:hint="17/06/2026"
                            android:inputType="none"
                            android:textColor="#222222"
                            android:textColorHint="#888888"
                            android:textSize="16sp"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ================= JAM PENGINGAT ================= -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Jam Pengingat"
                    android:textColor="#222222"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:id="@+id/imgJam"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_time"
                            android:tint="#D84EF7"/>

                        <EditText
                            android:id="@+id/edtJam"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:background="@android:color/transparent"
                            android:clickable="true"
                            android:cursorVisible="false"
                            android:focusable="false"
                            android:hint="08.00"
                            android:inputType="none"
                            android:textColor="#222222"
                            android:textColorHint="#888888"
                            android:textSize="16sp"/>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ================= HARI PENGINGAT ================= -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Ingatkan Di Hari"
                    android:textColor="#222222"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <!-- Baris 1 -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <!-- Senin -->

                    <Button
                        android:id="@+id/btnSen"
                        android:layout_width="75dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_day_selected"
                        android:text="Sen"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>

                    <!-- Selasa -->

                    <Button
                        android:id="@+id/btnSel"
                        android:layout_width="73dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_day"
                        android:text="Sel"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>

                    <!-- Rabu -->

                    <Button
                        android:id="@+id/btnRab"
                        android:layout_width="73dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_day"
                        android:text="Rab"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>


                    <!-- Kamis -->

                    <Button
                        android:id="@+id/btnKam"
                        android:layout_width="78dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_day"
                        android:text="Kam"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Baris 2 -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">


                    <!-- Jumat -->

                    <Button
                        android:id="@+id/btnJum"
                        android:layout_width="77dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_day"
                        android:text="Jum"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>

                    <!-- Sabtu -->

                    <Button
                        android:id="@+id/btnSab"
                        android:layout_width="75dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_day"
                        android:text="Sab"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>

                    <!-- Minggu -->

                    <Button
                        android:id="@+id/btnMin"
                        android:layout_width="75dp"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_day"
                        android:text="Min"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- ================= TOMBOL ================= -->

                <Button
                    android:id="@+id/btnSimpan"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="40dp"
                    android:background="@drawable/bg_button"
                    android:text="Simpan Catatan"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnBatal"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_button_outline"
                    android:text="Batal"
                    android:textAllCaps="false"
                    android:textColor="#8A8A8A"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <!-- Space supaya tidak mentok bawah -->

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="25dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>